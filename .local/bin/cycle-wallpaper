#!/bin/bash

wallpaper_dir="$HOME/Pictures/wallpapers"

# Load wallpapers into array
mapfile -t wallpapers < <(find "$wallpaper_dir" -type f \( -iname '*.jpg' -o -iname '*.png' -o -iname '*.jpeg' \) | sort)

# Get current wallpaper from awww
current_wall=$(awww query -j | jq -r '.[""][0].displaying.image')

# Find current index (0-based)
index=$(printf "%s\n" "${wallpapers[@]}" | grep -n -x "$current_wall" | cut -d: -f1)
index=$((index - 1))

# Compute next index (wrap around)
next_index=$(( (index + 1) % ${#wallpapers[@]} ))
next_wall="${wallpapers[$next_index]}"

# Set the wall
awww img "$next_wall" -t fade --transition-duration=0.4
