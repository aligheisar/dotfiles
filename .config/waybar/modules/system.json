{
  "tray": {
    "spacing": 10
  },
  "pulseaudio": {
    "format": "{icon} {volume}% | {format_source}",
    "format-bluetooth": "{volume}% {icon}ΎΛΦ | {format_source}",
    "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ | {format_source}",
    "format-muted": "Ύγσ | {format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 20
    },
    "format": "{icon} {capacity}%",
    "format-full": "{icon} {capacity}%",
    "format-charging": "ΎΩπ {capacity}%",
    "format-plugged": "ΎΘο {capacity}%",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },
  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "sway/workspaces": {
	"name": "workspaces",  
	"format": "{name}"
  },
  "sway/window": {
    "format": "{title}",
    "max-length": 30,
    "separate-outputs": true,
    "all-outputs": true,
    "return-type": "json",
    "rewrite": {
      "rewrite": {
        "": "{\"text\":\"έΑΦ\",\"class\":\"empty\"}",
        "*": "{\"text\":\"{title}\",\"class\":\"active\"}"
      }
    }
  }
}
