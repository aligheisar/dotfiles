{
  "Functional Component": {
    "prefix": "afc",
    "body": [
      "const ${1:ComponentName} = () => {",
      "\treturn (",
      "\t\t$2",
      "\t);",
      "};",
      "",
      "export { ${1} };"
    ]
  },

  "Next.js Page": {
    "prefix": "anp",
    "body": [
      "const ${1:PageName}Page = () => {",
      "\treturn (",
      "\t\t$2",
      "\t);",
      "};",
      "",
      "export default ${1}Page;"
    ]
  },

  "Next.js Layout": {
    "prefix": "anl",
    "body": [
      "const ${1:LayoutName}Layout = ({ children }: { children: React.ReactNode }) => {",
      "\treturn <${2:main}>{children}</${2}>;",
      "};",
      "",
      "export default ${1}Layout;"
    ]
  },

  "Next.js Context": {
    "prefix": "anc",
    "body": [
      "import { createContext } from \"react\";",
      "",
      "const ${1:MyContext} = createContext(null);",
      "",
      "export { ${1} };"
    ]
  },

  "Next.js Context Provider": {
    "prefix": "ancp",
    "body": [
      "\"use client\";",
      "",
      "import { ReactNode } from \"react\";",
      "import { ${1:MyContext} } from \"@/context/${2:context-name}\";",
      "",
      "const ${3:MyProvider} = ({ children }: { children: ReactNode }) => {",
      "\t${4:// state and logic here}",
      "",
      "\tconst contextValues = { $5 };",
      "\treturn <${1}.Provider value={contextValues}>{children}</${1}.Provider>;",
      "};",
      "",
      "export { ${3} };"
    ]
  },

  "Next.js Context Hook": {
    "prefix": "anch",
    "body": [
      "\"use client\";",
      "",
      "import { use } from \"react\";",
      "import { ${1:MyContext} } from \"@/context/${2:context-name}\";",
      "",
      "const use${3:MyHook} = () => {",
      "\tconst context = use(${1});",
      "\tif (!context) throw Error(\"Context must be used inside its provider\");",
      "\treturn context;",
      "};",
      "",
      "export { use${3} };"
    ]
  },

  "useState": {
    "prefix": "aus",
    "body": ["const [$1, set${1/(.*)/${1:/capitalize}/}] = useState($2);"]
  },

  "useEffect": {
    "prefix": "aue",
    "body": ["useEffect(() => {", "\t$1", "}, [$2]);"]
  }
}
